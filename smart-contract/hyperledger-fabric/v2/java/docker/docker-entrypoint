#!/bin/sh -euC

: "${CORE_PEER_TLS_ENABLED:='false'}"
: "${DEBUG:='false'}"

# JVM
OPTS='-Xss1M' # 512K doesn't seem to be enough for doDelivery...
# JML
OPTS="$OPTS -Dorg.jmlspecs.openjml.rac=exception"
# logging
OPTS="$OPTS -Dorg.slf4j.simpleLogger.defaultLogLevel=debug"
# profiling
OPTS="$OPTS -Dcom.sun.management.jmxremote"
OPTS="$OPTS -Dcom.sun.management.jmxremote.port=$JMX_PORT"
OPTS="$OPTS -Dcom.sun.management.jmxremote.local.only=false"
OPTS="$OPTS -Dcom.sun.management.jmxremote.authenticate=false"
OPTS="$OPTS -Dcom.sun.management.jmxremote.ssl=false"
OPTS="$OPTS -Dcom.sun.management.jmxremote.rmi.port=$JMX_PORT"
OPTS="$OPTS -Djava.rmi.server.hostname=$DOCKER_HOST_HOSTNAME"
# JFR
OPTS="$OPTS -XX:+FlightRecorder"
OPTS="$OPTS -XX:+StartFlightRecording=duration=300s,filename=/tmp/jfr/flight.jfr"

if [ "$DEBUG" = true ]; then
   exec java $OPTS -noverify -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=0.0.0.0:8000 -jar /chaincode.jar
else
   exec java $OPTS -noverify -jar /chaincode.jar
fi
